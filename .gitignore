# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/

# =============================================================================
# Environnements virtuels
# =============================================================================
.venv/
venv/
env/
ENV/
.env

# =============================================================================
# Données brutes et traitées (fichiers lourds — ne pas versionner)
# =============================================================================
data/raw/*
data/processed/*
data/splits/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/splits/.gitkeep

# =============================================================================
# Index (FAISS, BM25, hybride — fichiers binaires lourds)
# =============================================================================
indexes/bm25/*
indexes/dense/*
indexes/hybrid/*
!indexes/bm25/.gitkeep
!indexes/dense/.gitkeep
!indexes/hybrid/.gitkeep

# =============================================================================
# Résultats d'expériences (JSONL générés)
# =============================================================================
runs/A_ablation/*
runs/B_context_noise/*
runs/C_factuality/*
!runs/A_ablation/.gitkeep
!runs/B_context_noise/.gitkeep
!runs/C_factuality/.gitkeep

# =============================================================================
# Rapports générés (figures, logs, tableaux)
# =============================================================================
reports/figures/*
reports/logs/*
reports/tables/*
!reports/figures/.gitkeep
!reports/logs/.gitkeep
!reports/tables/.gitkeep

# =============================================================================
# Fichiers de modèles / checkpoints
# =============================================================================
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.gguf
*.pkl
*.pickle

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Éditeurs / IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Logs divers
# =============================================================================
*.log
*.out
*.err

# =============================================================================
# Requirements verrouillés (optionnel — décommenter pour le versionner)
# =============================================================================
# requirements.lock
